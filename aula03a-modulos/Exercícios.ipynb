   "source": [
    "# Exercício 1: abrir e reproduzir mp3\n",
    "import time\n",
    "from just_playback import Playback\n",
    "\n",
    "playback = Playback()\n",
    "playback.load_file('musica_exemplo.mp3')\n",
    "playback.play()\n",
    "\n",
    "time.sleep(5)\n",
    "\n",
    "playback.stop()\n",
    "print(\"Chega né amigo.\")\n"
   ]
  }
